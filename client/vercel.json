{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/seller", "destination": "/" },
    { "source": "/seller/", "destination": "/" },
    { "source": "/seller/:path*", "destination": "/:path*" }
  ]
}
