{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/smartstore", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/coupang", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/11st", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/gmarket", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/clothing-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/food-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/electronics-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/beauty-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/living-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/price/:amount", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/smartstore", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/coupang", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/11st", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/gmarket", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/clothing-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/food-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/electronics-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/beauty-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/living-fee-compare", "destination": "/seller/market-compare", "permanent": true },
    { "source": "/seller/price/:amount", "destination": "/seller/market-compare", "permanent": true }
  ],
  "rewrites": [
    { "source": "/seller", "destination": "/" },
    { "source": "/seller/", "destination": "/" },
    { "source": "/seller/:path*", "destination": "/:path*" }
  ]
}
