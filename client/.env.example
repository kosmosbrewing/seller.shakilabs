# Frontend-only 정적 사이트 환경 변수 예시
# 모두 선택사항이며, 비워두면 해당 기능이 비활성화됩니다.

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
# 로컬 개발 시 GA 디버그 로그 활성화 여부 (true/false)
VITE_GA_DEBUG=false

# Google AdSense 퍼블리셔 ID (예: ca-pub-1234567890123456)
VITE_ADSENSE_PUBLISHER_ID=
# AdSense 슬롯 ID (숫자 문자열)
VITE_ADSENSE_SLOT_TOP=
VITE_ADSENSE_SLOT_MIDDLE=
VITE_ADSENSE_SLOT_BOTTOM=

# KakaoTalk 공유 SDK JavaScript 키
VITE_KAKAO_JS_KEY=
# 사이트 절대 URL (공유 링크/SEO canonical 생성에 사용)
VITE_SITE_URL=https://seller.shakilabs.com
