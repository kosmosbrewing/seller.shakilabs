{
  "installCommand": "cd client && npm ci",
  "buildCommand": "cd client && npm run build",
  "outputDirectory": "client/dist",
  "redirects": [
    { "source": "/smartstore", "destination": "/market-compare", "permanent": true },
    { "source": "/coupang", "destination": "/market-compare", "permanent": true },
    { "source": "/11st", "destination": "/market-compare", "permanent": true },
    { "source": "/gmarket", "destination": "/market-compare", "permanent": true },
    { "source": "/clothing-fee-compare", "destination": "/market-compare", "permanent": true },
    { "source": "/food-fee-compare", "destination": "/market-compare", "permanent": true },
    { "source": "/electronics-fee-compare", "destination": "/market-compare", "permanent": true },
    { "source": "/beauty-fee-compare", "destination": "/market-compare", "permanent": true },
    { "source": "/living-fee-compare", "destination": "/market-compare", "permanent": true },
    { "source": "/price/:amount", "destination": "/market-compare", "permanent": true }
  ],
  "headers": [
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
